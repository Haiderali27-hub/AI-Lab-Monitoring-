<Window x:Class="Student_Desktop_App.Views.ExamDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartExam Dashboard"
        Height="640"
        Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
                    <TextBlock Text="Time Remaining" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding RemainingTime}" FontSize="24" FontWeight="Bold" Foreground="#0F766E" HorizontalAlignment="Right" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Exam Dashboard" FontSize="24" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="{Binding ExamName}" FontSize="18" Margin="0,8,0,0" Foreground="#1F2937" />

                <WrapPanel Margin="0,16,0,0">
                    <Border Background="#EEF2FF" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Status" FontSize="11" Foreground="#6B7280" />
                            <TextBlock Text="{Binding ExamStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#3730A3" />
                        </StackPanel>
                    </Border>

                    <Border Background="#ECFEFF" CornerRadius="6" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Monitoring" FontSize="11" Foreground="#6B7280" />
                            <TextBlock Text="{Binding MonitoringStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#155E75" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <TextBlock Text="{Binding Message}"
                           Margin="0,18,0,0"
                           TextWrapping="Wrap"
                           Foreground="#111827"
                           FontSize="14" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    Width="100"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="StartExamButton"
                    Content="Start Exam"
                    Width="120"
                    Height="34"
                    Margin="0,0,8,0"
                    Background="#2563EB"
                    Foreground="White"
                    Click="StartExamButton_OnClick" />
            <Button x:Name="LogoutButton"
                    Content="Logout"
                    Width="100"
                    Height="34"
                    Background="#DC2626"
                    Foreground="White"
                    Click="LogoutButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>