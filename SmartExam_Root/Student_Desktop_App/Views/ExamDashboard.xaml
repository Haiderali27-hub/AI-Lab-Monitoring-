<Window x:Class="Student_Desktop_App.Views.ExamDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartExam Dashboard"
        Height="680"
        Width="1120"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Background="#F2F5FA">
        <Border CornerRadius="24"
                Background="#FFFFFF"
                Padding="24"
                Margin="20"
                BorderBrush="#E3E8F2"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" Opacity="0.18" ShadowDepth="0" Color="#1B2A4A" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="SmartExam Exam Dashboard" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock Text="{Binding StudentDisplayName}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Background="#EEF2FF" CornerRadius="999" Padding="8,2" Margin="0,0,6,0">
                                <TextBlock Text="Lab" FontSize="10" FontWeight="Bold" Foreground="#1D4ED8" />
                            </Border>
                            <TextBlock Text="{Binding LabName}" FontSize="11" Foreground="#475569" VerticalAlignment="Center" />
                            <Border Background="#EEF2FF" CornerRadius="999" Padding="8,2" Margin="16,0,6,0">
                                <TextBlock Text="Proctor" FontSize="10" FontWeight="Bold" Foreground="#1D4ED8" />
                            </Border>
                            <TextBlock Text="{Binding ProctorName}" FontSize="11" Foreground="#475569" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="Time Remaining" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding RemainingTime}" FontSize="26" FontWeight="Bold" Foreground="#0B4EC6" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="16" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding ExamName}" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Border Background="#E8F0FE" CornerRadius="10" Padding="10,6" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Status" FontSize="11" Foreground="#64748B" />
                                        <TextBlock Text="{Binding ExamStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#1D4ED8" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#ECFEFF" CornerRadius="10" Padding="10,6">
                                    <StackPanel>
                                        <TextBlock Text="Monitoring" FontSize="11" Foreground="#64748B" />
                                        <TextBlock Text="{Binding MonitoringStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#0F766E" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Instructions" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,16,0,6" />
                            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12">
                                <TextBlock Text="{Binding Instructions}" TextWrapping="Wrap" Foreground="#334155" FontSize="12" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#0B4EC6" CornerRadius="16" Padding="16" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Session Status" FontSize="12" Foreground="#E2E8F0" />
                            <TextBlock Text="{Binding Message}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RefreshButton"
                            Content="Refresh"
                            Width="110"
                            Height="36"
                            Margin="0,0,8,0"
                            Background="#F1F5F9"
                            BorderBrush="#E2E8F0"
                            Click="RefreshButton_OnClick" />
                    <Button x:Name="StartExamButton"
                            Content="Start Exam"
                            Width="130"
                            Height="36"
                            Margin="0,0,8,0"
                            Background="#0B4EC6"
                            Foreground="White"
                            BorderThickness="0"
                            Click="StartExamButton_OnClick" />
                    <Button x:Name="LogoutButton"
                            Content="Logout"
                            Width="110"
                            Height="36"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Click="LogoutButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>