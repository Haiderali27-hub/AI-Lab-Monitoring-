<Window x:Class="Student_Desktop_App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartExam Secure Authentication"
        Height="560"
        Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">
    <Grid Background="#F2F5FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border CornerRadius="28"
                Background="White"
                Padding="28"
                Margin="24"
                BorderBrush="#E3E8F2"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Opacity="0.18" ShadowDepth="0" Color="#1B2A4A" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="12" Background="#EEF2FF">
                            <TextBlock Text="SE"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1E40AF"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="SmartExam Control Center" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="#E8F0FE" CornerRadius="999" Padding="8,2" Margin="0,0,6,0">
                                    <TextBlock Text="LAN SECURE" FontSize="10" FontWeight="Bold" Foreground="#1D4ED8" />
                                </Border>
                                <Border Background="#E8F0FE" CornerRadius="999" Padding="8,2">
                                    <TextBlock Text="STUDENT CLIENT" FontSize="10" FontWeight="Bold" Foreground="#1D4ED8" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                        <Button Grid.Column="1"
                            Content="X"
                            Width="28"
                            Height="28"
                            FontSize="12"
                            Background="#F1F5F9"
                            BorderThickness="0"
                            Foreground="#1F2937"
                            Click="CloseButton_Click" />
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <TextBlock Text="Institution Access" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" />
                    <ComboBox Height="36" Margin="0,6,0,12" Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A">
                        <ComboBoxItem Content="Select Campus / Site" IsEnabled="False" />
                        <ComboBoxItem Content="Main Campus - Lab Alpha" />
                    </ComboBox>

                    <TextBlock Text="Email or Username" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" />
                    <TextBox Height="36"
                             Margin="0,6,0,12"
                             Background="#F1F5F9"
                             BorderBrush="#E2E8F0"
                             Foreground="#0F172A"
                             Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Password" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordInput"
                                 Height="36"
                                 Margin="0,6,0,12"
                                 Background="#F1F5F9"
                                 BorderBrush="#E2E8F0"
                                 Foreground="#0F172A" />

                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LOCK" FontSize="11" FontWeight="SemiBold" Foreground="#1D4ED8" />
                            <TextBlock Text="Secure Session Enabled (AES-256)" FontSize="11" Foreground="#475569" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="LoginButton"
                            Content="Authenticate Access"
                            Height="40"
                            FontWeight="SemiBold"
                            Background="#0B4EC6"
                            Foreground="White"
                            BorderThickness="0"
                            Click="LoginButton_OnClick" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" Foreground="#64748B" />
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" FontSize="11" Foreground="#334155" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>