<Window x:Class="Student_Desktop_App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartExam Secure Authentication"
        Height="500"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">
                         Height="34"
                         Margin="0,4,0,12"
                         Padding="8,4"
                         Background="#0D1117"
                         Foreground="#E6EDF3"
                         BorderBrush="#30363D" />

                <TextBlock Text="Password"
                           Foreground="#8B949E"
                           FontSize="12" />
                <PasswordBox x:Name="PasswordInput"
                             Height="34"
                             Margin="0,4,0,16"
                             Padding="8,4"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             BorderBrush="#30363D" />

                <Button x:Name="LoginButton"
                        Content="Login"
                        Height="36"
                        FontWeight="SemiBold"
                        Background="#238636"
                        Foreground="White"
                        Click="LoginButton_OnClick" />

                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           Foreground="#C9D1D9"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>