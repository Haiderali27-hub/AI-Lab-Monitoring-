{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=smartexam_dev_db;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "SmartExam",
    "Audience": "SmartExamClients",
    "Key": "change-this-development-key-to-a-long-random-secret-at-least-32-chars",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 1,
    "HwidPepper": "change-this-hwid-pepper-for-production"
  },
  "Monitoring": {
    "HeartbeatSeconds": 10,
    "OfflineAfterSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
